#ifdef _WIN32
LANGUAGE LANG_KOREAN, SUBLANG_DEFAULT
#pragma code_page(65001)
#endif //_WIN32

/////////////////////////////////////////////////////////////////////////////
//
// Menu
//

IDR_MAIN MENU
BEGIN
    POPUP "파일(&F)"
    BEGIN
        MENUITEM "새 파일(&N)\tCtrl+N",           ID_CMD_NEWFILE
        MENUITEM SEPARATOR
        MENUITEM "열기(&O)...\tCtrl+O",            ID_CMD_OPENFILE
        MENUITEM "다시 열기(&R)...\tCtrl+R",          ID_CMD_REOPENFILE
        MENUITEM "새로 고침(&F)\tF5",                ID_CMD_REFRESHFILE
        MENUITEM "관리자 권한으로 열기(&L)...\tCtrl+L",   ID_CMD_OPENELEVATED
        MENUITEM SEPARATOR
        MENUITEM "저장(&S)\tCtrl+S",               ID_CMD_SAVEFILE
        MENUITEM "다른 이름으로 저장(&A)...\tCtrl+Shift+S",   ID_CMD_SAVEFILEAS
        MENUITEM SEPARATOR
        MENUITEM "인쇄(&P)...\tCtrl+P",           ID_CMD_PRINT
        MENUITEM "인쇄 설정(&U)...",               ID_CMD_PAGESETUP
        MENUITEM SEPARATOR
        POPUP "최근 파일(&M)"
        BEGIN
            MENUITEM "(no files)",                  ID_MENUITEM40030, GRAYED
        END
        MENUITEM SEPARATOR
        MENUITEM "저장하고 종료(&I)\tCtrl+E",   ID_CMD_SAVEEXIT
        MENUITEM "저장하지 않고 종료(&D)\tCtrl+Shift+E",   ID_CMD_DISCARDEXIT
        MENUITEM "종료(&X)",                       ID_CMD_EXIT
    END
    POPUP "편집(&E)"
    BEGIN
        MENUITEM "실행 취소(&U)\tCtrl+Z",               ID_CMD_UNDO
        MENUITEM "다시 실행(&R)\tCtrl+Y",               ID_CMD_REDO
        MENUITEM SEPARATOR
        MENUITEM "잘라내기(&X)\tCtrl+X",                ID_CMD_CUT
        MENUITEM "복사(&C)\tCtrl+C",               ID_CMD_COPY
        MENUITEM "붙여넣기(&P)\tCtrl+V",              ID_CMD_PASTE

        MENUITEM "삭제(&D)\tDel",                ID_CMD_DELETE
        MENUITEM SEPARATOR
        MENUITEM "모두 선택(&A)\tCtrl+A",         ID_CMD_SELECTALL
        MENUITEM SEPARATOR
        MENUITEM "날짜/시간 삽입(&T)\tF6",      ID_CMD_DATETIME
        MENUITEM "유니코드 삽입(&N)...\tCtrl+I",   ID_CMD_INSERTUNI
        MENUITEM SEPARATOR
        POPUP "변경(&M)"
        BEGIN
            MENUITEM "대문자(&U)\tAlt+U",          ID_CMD_UPPERCASE
            MENUITEM "소문자(&L)\tAlt+L",          ID_CMD_LOWERCASE
            MENUITEM "대소문자 반전(&I)\tAlt+I",         ID_CMD_INVERTCASE
            MENUITEM "ASCII로 변환(&R)\tAlt+R",     ID_CMD_ASCIIFY
            MENUITEM "줄 끝 공백 제거(&T)\tAlt+W",ID_CMD_TTSPACES
            MENUITEM "첫 글자 제거(&F)\tAlt+Z",ID_CMD_SFCHAR
            MENUITEM "마지막 글자 제거(&A)\tAlt+A",ID_CMD_SLCHAR
            MENUITEM "따옴표 추가(&Q)\tAlt+Q",               ID_CMD_QUOTE
            MENUITEM "따옴표 제거(&N)\tAlt+N",             ID_CMD_UNQUOTE
        END
        POPUP "Unic&ode NF"
        BEGIN
            MENUITEM "NF&C (composed)",                  ID_CMD_UNINORMC
            MENUITEM "NF&D (decomposed)",                ID_CMD_UNINORMD
            MENUITEM "NF&KC (compatibility composed)",   ID_CMD_UNINORMKC
            MENUITEM "&NFKD (compatibility decomposed)", ID_CMD_UNINORMKD
        END
      # ifndef NO_IME
        MENUITEM SEPARATOR
        MENUITEM "재변환(&V)",               ID_CMD_RECONV
        MENUITEM "IME 켜기/끄기(&I)",                 ID_CMD_TOGGLEIME
      # endif

    END
    POPUP "찾기(&S)"
    BEGIN
        MENUITEM "찾기 및 바꾸기(&F)\tCtrl+F",               ID_CMD_FIND
        MENUITEM "다음 찾기(&N)\tF3",              ID_CMD_FINDNEXT
        MENUITEM "이전 찾기(&P)\tShift+F3",        ID_CMD_FINDPREV
        MENUITEM SEPARATOR
        MENUITEM "줄로 이동(&J)\tCtrl+J",       ID_CMD_JUMP
        MENUITEM SEPARATOR
        MENUITEM "Grep(&G)...\tCtrl+G",            ID_CMD_GREP
        MENUITEM "선택한 파일 열기(&O)...\tF7",      ID_CMD_OPENSELECTION
    END
    POPUP "보기(&V)"
    BEGIN
        MENUITEM "줄 바꿈 안 함(&N)\tCtrl+1",        ID_CMD_NOWRAP
        MENUITEM "지정된 너비로 줄 바꿈(&W)\tCtrl+2", ID_CMD_WRAPWIDTH
        MENUITEM "창 끝에서 줄 바꿈(&R)\tCtrl+3", ID_CMD_WRAPWINDOW
        MENUITEM SEPARATOR
        MENUITEM "확대/축소 설정(&S)...",                 ID_CMD_ZOOMDLG
        MENUITEM "확대/축소 초기화(&E)",                  ID_CMD_ZOOMRZ
        MENUITEM "확대(&U)",                     ID_CMD_ZOOMUP
        MENUITEM "축소(&W)",                   ID_CMD_ZOOMDN
        MENUITEM SEPARATOR
        POPUP "파일 형식(&T)"
        BEGIN
            MENUITEM "(기본값)",                       ID_MENUITEM40025
        END
        MENUITEM "설정(&S)...",                ID_CMD_CONFIG
        MENUITEM SEPARATOR
        MENUITEM "상태 표시줄(&B)",                  ID_CMD_STATUSBAR
    END
    POPUP "도움말(&H)"
    BEGIN
        MENUITEM "도움말(&C)...\tF1",         ID_CMD_HELP
        MENUITEM "정보(&A)",    ID_CMD_HELPABOUT
    END
END



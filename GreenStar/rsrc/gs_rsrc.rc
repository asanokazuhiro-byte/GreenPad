    RTEXT           "&Undo:",IDC_STATIC,9,24,73,8
    AUTORADIOBUTTON "Infinite",IDC_UNDOLIM1,86,24,40,8, WS_GROUP
    AUTORADIOBUTTON "",IDC_UNDOLIM2,130,24,11,8
    EDITTEXT        IDC_UNDO_CT,139,22,12,10,ES_AUTOHSCROLL | ES_NUMBER
    LTEXT           "times",IDC_STATIC,155,24,10,8
    RTEXT           "&Column by:",IDC_STATIC,9,37,73,8
    AUTORADIOBUTTON "Letters",IDC_COUNTBYLETTER,86,36,33,10, WS_GROUP
    AUTORADIOBUTTON "Positions",IDC_COUNTBYLETTER2,130,36,42,10
    RTEXT           "M&RU File Num:",IDC_STATIC,9,50,73,8
    EDITTEXT        IDC_LATEST_NUM,86,48,32,12,ES_AUTOHSCROLL | ES_NUMBER
    RTEXT           "TextFile &Filter:",IDC_STATIC,9,65,73,8
    EDITTEXT        IDC_TXTFILT,86,63,182,12,ES_AUTOHSCROLL
    RTEXT           "External &Grep Program:",IDC_STATIC,9,80,73,8
    EDITTEXT        IDC_EXTGREP,86,78,182,12,ES_AUTOHSCROLL
    RTEXT           "&New File Mode:",IDC_STATIC,9,94,73,8
    COMBOBOX        IDC_NEWCS,86,92,76,162,CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    COMBOBOX        IDC_NEWLB,164,92,39,162,CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    COMBOBOX        IDC_NEWDT,204,92,65,164,CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    AUTOCHECKBOX    "Open in Same &Window",IDC_OPENSAME,181,25,90,10
    AUTOCHECKBOX    "Remember Window &Size",IDC_REMSIZE,181,35,96,10
    AUTOCHECKBOX    "Remember Window &Pos",IDC_REMPLACE,181,45,94,10
    GROUPBOX        "&Document Types",IDC_STATIC,7,118,274,92
    LISTBOX         IDC_DOCTYPELIST,15,133,88,53,LBS_NOINTEGRALHEIGHT | WS_VSCROLL | WS_TABSTOP
    PUSHBUTTON      "Add",IDC_NEWDOCTYPE,17,191,29,14
    PUSHBUTTON      "Del",IDC_DELDOCTYPE,48,191,29,14
    RTEXT           "P&attern:",IDC_STATIC,114,138,27,8
    EDITTEXT        IDC_DT_PAT,146,135,127,12,ES_AUTOHSCROLL
    RTEXT           "&Keyword:",IDC_STATIC,108,155,34,8
    COMBOBOX        IDC_PAT_KWD,146,152,75,172,CBS_DROPDOWNLIST | CBS_SORT | CBS_NOINTEGRALHEIGHT | WS_VSCROLL | WS_TABSTOP
    PUSHBUTTON      "edit",IDC_EDITKWD,231,152,19,14
    RTEXT           "&Layout:",IDC_STATIC,111,172,31,8
    COMBOBOX        IDC_PAT_LAY,146,169,75,172,CBS_DROPDOWNLIST | CBS_SORT | CBS_NOINTEGRALHEIGHT | WS_VSCROLL | WS_TABSTOP
    PUSHBUTTON      "edit",IDC_EDITLAY,231,169,19,14

    DEFPUSHBUTTON   "OK",IDOK,175,214,50,14
    PUSHBUTTON      "Cancel",IDCANCEL,230,214,50,14
END




IDD_REOPENDLG DIALOG  0, 0, 187, 54
STYLE DS_SETFONT | DS_MODALFRAME | DS_3DLOOK | DS_CENTER | WS_VISIBLE |
    WS_CLIPSIBLINGS | WS_CAPTION | WS_SYSMENU
CAPTION "ReOpen File"
FONT 9, MYDIALOGFONT
BEGIN
    LTEXT           "&Character Encoding:",IDC_STATIC,9,13,42,8
    COMBOBOX        IDC_CODELIST,59,11,111,103,CBS_DROPDOWN | WS_VSCROLL | WS_TABSTOP
    PUSHBUTTON      "OK",IDOK,66,32,56,14
    PUSHBUTTON      "Cancel",IDCANCEL,125,32,56,14
END

IDD_JUMP DIALOG  0, 0, 131, 43
STYLE DS_ABSALIGN | DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP |
    WS_CAPTION | WS_SYSMENU
CAPTION "Jump To"
FONT 9, MYDIALOGFONT
BEGIN
    DEFPUSHBUTTON   "&Go!",IDOK,87,12,25,14
    EDITTEXT        IDC_LINEBOX,14,13,40,12,ES_AUTOHSCROLL
    LTEXT           "&Line",IDC_LINLABEL,61,15,22,8
END


IDD_FINDREPLACE DIALOG  0, 0, 316, 84
STYLE DS_SETFONT | DS_MODALFRAME | DS_SETFOREGROUND | DS_CENTER | WS_POPUP |
    WS_CAPTION | WS_SYSMENU
CAPTION "Find & Replace"
FONT 9, MYDIALOGFONT
BEGIN
    RTEXT           "Fi&nd:",IDC_STATIC,5,10,61,8
    COMBOBOX        IDC_FINDBOX,70,9,120,100, CBS_AUTOHSCROLL | CBS_DROPDOWN | WS_VSCROLL | WS_TABSTOP
    RTEXT           "Re&place:",IDC_STATIC,5,31,61,8
    COMBOBOX        IDC_REPLACEBOX,70,28,120,100, CBS_AUTOHSCROLL | CBS_DROPDOWN | WS_VSCROLL | WS_TABSTOP
    DEFPUSHBUTTON   "&Find",ID_FINDNEXT,195,8,56,14
    PUSHBUTTON      "Find&Prev",ID_FINDPREV,255,8,56,14
    PUSHBUTTON      "&Replace",ID_REPLACENEXT,195,27,56,14
    PUSHBUTTON      "Replace&All",ID_REPLACEALL,255,27,56,14
    GROUPBOX        "&Options",IDC_STATIC,12,47,240,27
    AUTOCHECKBOX    "&Ignore Case",IDC_IGNORECASE,22,59,100,10
    AUTOCHECKBOX    "Regular E&xpression",IDC_REGEXP,125,59,135,10
    PUSHBUTTON      "Close",IDCANCEL,255,59,56,14
END


IDD_ABOUTDLG DIALOG  0, 0, 180, 118
STYLE DS_SETFONT | DS_MODALFRAME | DS_SETFOREGROUND | DS_CENTER | WS_POPUP |
    WS_CAPTION | WS_SYSMENU
CAPTION "About GreenStar"
FONT 9, MYDIALOGFONT
BEGIN
    ICON            IDR_MAIN,  IDC_STATIC, 8,8,0,0
    EDITTEXT        IDC_ABOUTSTR, 40,8,135,32, ES_MULTILINE | ES_READONLY | NOT WS_BORDER |  NOT WS_TABSTOP

    LTEXT           "Written by k.inaba 2002-2008\nDerived by roytam1 and RamonUnch\nFurther modified by ASANO, Kazuhiro", IDC_STATIC,8,50,140,24
    EDITTEXT        IDC_ABOUTURL, 8,78,172,8, ES_MULTILINE | ES_READONLY | NOT WS_BORDER |  NOT WS_TABSTOP

    PUSHBUTTON      "Close",IDCANCEL,70,96,40,14
END


IDD_ADDDOCTYPE DIALOG  0, 0, 123, 67
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "New DocType"
FONT 9, MYDIALOGFONT
BEGIN
